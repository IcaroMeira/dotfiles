#!/bin/bash

sudo pacman -Syyu
~/dotfiles/dot-scripts/scripts/install-yay
~/dotfiles/dot-scripts/scripts/install-packages

xdg-user-dirs-update
~/dotfiles/dot-scripts/scripts/reload-links

cd ~/dotfiles/dwm/
sudo make clean install
cd ~/dotfiles/dwmblocks-async/
sudo make clean install
cd ~/dotfiles/st
sudo make clean install
reboot
