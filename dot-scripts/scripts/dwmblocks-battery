#!/bin/bash

state=$(acpi | awk -F' ' '{print $3}' | sed 's/,//')
perc=$(acpi | awk -F', ' '{print $2}' | sed 's/%//')
case $state in
    Charging)
        if [[ perc -le 20 ]] then
            icon="َ°¢œ"
        elif [[ perc -le 40 && perc -gt 20 ]] then
            icon="َ°‚‡"
        elif [[ perc -le 60 && perc -gt 40 ]] then
            icon="َ°¢‌"
        elif [[ perc -le 80 && perc -gt 60 ]] then
            icon="َ°¢‍"
        elif [[ perc -lt 100 && perc -gt 80 ]] then
            icon="َ°‚‹"
        else
            icon="َ°پ¹"
        fi;;
    *)
        if [[ perc -le 20 ]] then
            icon="َ±ƒچ"
        elif [[ perc -le 40 && perc -gt 20 ]] then
            icon="َ°پ¼"
        elif [[ perc -le 60 && perc -gt 40 ]] then
            icon="َ°پ¾"
        elif [[ perc -le 80 && perc -gt 60 ]] then
            icon="َ°‚€"
        elif [[ perc -lt 100 && perc -gt 80 ]] then
            icon="َ°‚‚"
        else
            icon="َ°پ¹"
        fi;;
esac
echo $perc% $icon
